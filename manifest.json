{
  "manifest_version": 3,
  "name": "TimeShift: Global Timezone Converter",
  "version": "2.1.0",
  "description": "Convert dates/times between any timezones with intelligent detection and context menu integration",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Convert Timezone"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
